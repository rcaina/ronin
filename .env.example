# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET= # Generated by create-t3-app.
NEXTAUTH_URL=http://localhost:3000

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL=

NODE_ENV=development

AUTH_ALLOWED_EMAILS=

RESEND_API_KEY=

# Receipt scanning (vision + extraction). Provider-agnostic — set ONE key.
# AI_PROVIDER is optional; if unset it auto-detects (Gemini preferred for its
# free tier). Override the model per provider if you like.
# AI_PROVIDER=gemini
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# Stripe billing (subscriptions). Optional in dev — billing routes guard at
# runtime when unset.
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# Price IDs from the "Ronin Premium" product (monthly + annual recurring prices)
STRIPE_PRICE_MONTHLY_ID=
STRIPE_PRICE_ANNUAL_ID=

# Cron (Feature 2 — Recurring transactions). Shared secret verified against
# the cron job's `Authorization: Bearer` header. Vercel Cron sends this
# automatically when an env var named exactly CRON_SECRET is set. Required in
# production. Generate with: openssl rand -hex 32
CRON_SECRET=""

# Web push (Feature 5 — Notifications). All optional: in-app notifications
# work without these, and the push sender no-ops when unset. Generate the
# key pair together with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=""
# Contact URI required by the Push spec — any mailto: you own.
VAPID_SUBJECT="mailto:you@example.com"
# Public half of the VAPID pair (must match VAPID_PRIVATE_KEY from the same run).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""